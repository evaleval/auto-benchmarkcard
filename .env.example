# Copy this file to .env and fill in your values.
#
# Only HF_TOKEN is required. The default models work well
# but you can swap them for any model available on HF Inference.

LLM_ENGINE_TYPE=hf

HF_TOKEN=<your-huggingface-token>
# HF_ORG=<your-org>                          # optional: org billing

HF_COMPOSER_MODEL=deepseek-ai/DeepSeek-V3.1
FACTREASONER_MODEL=meta-llama/Llama-3.3-70B-Instruct

# For local inference with Ollama instead:
# LLM_ENGINE_TYPE=ollama
# OLLAMA_API_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3:27b
